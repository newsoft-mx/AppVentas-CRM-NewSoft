# === BASE DE DATOS (Vercel + Supabase) ===
# URL con pgbouncer (pooled) — usada en runtime por Prisma
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# URL directa sin pgbouncer — usada por prisma migrate deploy
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:5432/postgres"

# === AUTENTICACIÓN ===
# Secreto para firmar JWT de sesión — generar con: openssl rand -base64 32
SESSION_SECRET="tu-secreto-muy-seguro-aqui-al-menos-32-chars"

# === ENTORNO ===
NODE_ENV="development"
